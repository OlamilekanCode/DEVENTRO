# Local admin login used by /admin.
ADMIN_EMAIL="admin@deventro.site"
ADMIN_PASSWORD="change-this-password"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# Optional for non-interactive Cloudflare deploys.
# Wrangler can also use `wrangler login` instead.
CLOUDFLARE_ACCOUNT_ID="00000000000000000000000000000000"
CLOUDFLARE_API_TOKEN="dummy-cloudflare-api-token"
